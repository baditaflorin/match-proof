{
  "name": "match-proof",
  "private": true,
  "version": "0.1.0",
  "description": "Privacy-preserving peer matching for shared attributes using browser crypto, WebRTC, Bloom filters, and local inference.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "smoke": "bash scripts/smoke.sh",
    "lint": "eslint .",
    "preview": "vite preview --host 127.0.0.1",
    "pages-preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@digitalbazaar/bbs-signatures": "^3.0.0",
    "@noble/hashes": "^1.8.0",
    "@tanstack/react-query": "^5.100.9",
    "comlink": "^4.4.2",
    "idb": "^8.0.3",
    "lucide-react": "^1.14.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "gzip-size-cli": "^5.1.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5"
  }
}
